# Конфигурационный файл AmneziaWG
# Замените все значения на реальные данные вашего сервера.
#
# Как получить этот конфиг:
#   1. Откройте приложение Amnezia VPN
#   2. Настройки → Серверы → ваш сервер
#   3. Поделиться → Экспорт как WireGuard/AmneziaWG конфиг
#   4. Сохраните файл и укажите путь к нему в setup.sh
#
# Или создайте вручную на VPS — см.:
#   https://docs.amnezia.org/

[Interface]
PrivateKey = YOUR_PRIVATE_KEY_HERE
Address = 10.8.1.2/32
DNS = 1.1.1.1, 8.8.8.8

# Параметры обфускации AmneziaWG (необязательны для стандартного WireGuard)
Jc = 4
Jmin = 40
Jmax = 70
S1 = 0
S2 = 0
H1 = 1
H2 = 2
H3 = 3
H4 = 4

[Peer]
PublicKey = YOUR_SERVER_PUBLIC_KEY_HERE
PresharedKey = YOUR_PRESHARED_KEY_HERE
AllowedIPs = 0.0.0.0/0
Endpoint = YOUR_SERVER_IP:YOUR_PORT
PersistentKeepalive = 25
